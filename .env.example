# ─────────────────────────────────────────────
#  ELLEY — AI Roofing Receptionist
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Anthropic (Claude AI) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Twilio (SMS + Voice) ────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX     # Your Twilio number (with country code)

# ── Business Config ─────────────────────────
COMPANY_NAME=Your Roofing Company
BUSINESS_PHONE=+1XXXXXXXXXX          # Your real business phone (for SMS alerts)
OWNER_PHONE=+1XXXXXXXXXX             # Owner's cell — receives high-priority alerts
FORWARD_PHONE=+1XXXXXXXXXX           # Phone to forward live calls to (optional)

# ── App Config ──────────────────────────────
PORT=3000
BASE_URL=https://your-domain.com     # Your public URL (ngrok or production)
NODE_ENV=development                 # Set to 'production' to enable Twilio sig validation

# ── Dashboard Security ───────────────────────
DASHBOARD_API_KEY=change-me-to-a-secure-random-string

# ── Booking (optional) ───────────────────────
BOOKING_URL=https://calendly.com/your-link   # Elley will share this in SMS when booking

# ── Voice ────────────────────────────────────
TWILIO_VOICE=Polly.Joanna-Neural     # AWS Polly neural voice (or any Twilio voice)
